# Copy to .env and fill in. NEVER commit .env or real values (spec §11.1).

# dev | test | prod
ENVIRONMENT=dev

# PostgreSQL connection string (Railway provides this in prod)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/betting

# Comma-separated exact origins allowed by CORS (the Vercel domain in prod)
CORS_ORIGINS=http://localhost:5173

# Protects write/job routes via the X-API-Key header. Required in prod.
API_KEY=

# API-Football (https://dashboard.api-football.com) — fixtures/results
API_FOOTBALL_KEY=

# The Odds API (https://the-odds-api.com) — odds snapshots incl. Pinnacle
THE_ODDS_API_KEY=

# Ingestion target (defaults: Brasileirão Série A 2026)
INGEST_LEAGUE_PROVIDER_ID=71
INGEST_SEASON=2026
ODDS_SPORT_KEY=soccer_brazil_campeonato
ODDS_REGIONS=eu
ODDS_MARKETS=h2h,totals

# In-process job scheduler (enable in prod / long-running dev)
SCHEDULER_ENABLED=false
